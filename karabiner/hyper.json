{
    "title": "Hyper key (keyboard-first workflow)",
    "rules": [
        {
            "description": "Caps Lock → Hyper (⌃⌥⇧⌘) when held, Escape when tapped",
            "manipulators": [
                {
                    "type": "basic",
                    "from": {
                        "key_code": "caps_lock",
                        "modifiers": { "optional": ["any"] }
                    },
                    "to": [
                        {
                            "key_code": "left_shift",
                            "modifiers": ["left_command", "left_control", "left_option"]
                        }
                    ],
                    "to_if_alone": [{ "key_code": "escape" }]
                }
            ]
        }
    ]
}
